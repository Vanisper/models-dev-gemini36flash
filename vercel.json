{
  "version": 2,
  "framework": "vite",
  "buildCommand": "pnpm run update-data && pnpm run build",
  "outputDirectory": "packages/frontend/dist",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
