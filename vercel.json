{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm run update-data && pnpm --filter @catalog/frontend build && pnpm --filter @catalog/backend build",
  "outputDirectory": "packages/frontend/dist",
  "functions": {
    "api/index.ts": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
